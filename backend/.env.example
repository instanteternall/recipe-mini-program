# 示例环境变量配置

# Railway 环境变量设置
SPOONACULAR_API_KEY=your_spoonacular_api_key_here
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your_wechat_secret_here
NODE_ENV=production
PORT=3000

# Vercel 环境变量设置（如果选择Vercel）
# 在Vercel控制台的Settings > Environment Variables中添加以上变量

# 本地开发环境变量（.env文件）
# 复制此文件为 .env 并填入真实值
SPOONACULAR_API_KEY=your_spoonacular_api_key_here
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your_wechat_secret_here
NODE_ENV=development
PORT=3000