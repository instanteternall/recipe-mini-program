PORT=3000
NODE_ENV=production

# API Provider选择: juhe 或 themealdb
# juhe: 聚合数据API (50次/天，中文菜谱)
# themealdb: TheMealDB (免费无限制，英文菜谱)
API_PROVIDER=themealdb

# JuHe Data API (菜谱API) - 支持多账号轮换
# 格式: key1,key2,key3 (用逗号分隔)
JUHE_API_KEYS=12be18fba59f76f071b14b23df49804c

# 兼容旧配置（单个Key）
JUHE_API_KEY=12be18fba59f76f071b14b23df49804c

# 每个Key的请求次数限制（聚合数据默认50次/天）
JUHE_API_LIMIT=50

# TheMealDB API (完全免费，无限制)
THEMEALDB_API_KEY=1

# WeChat Mini Program
WECHAT_APPID=wx22b7624e6414c963
WECHAT_SECRET=fb4b8db18fea7a84952fa3e0f7551451