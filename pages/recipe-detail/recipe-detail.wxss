/* pages/recipe-detail/recipe-detail.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 菜谱头部 */
.recipe-header {
  background-color: #fff;
  margin-bottom: 10px;
}

.image-swiper {
  height: 250px;
}

.recipe-image {
  width: 100%;
  height: 100%;
}

.recipe-info {
  padding: 16px;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
}

.meta-item {
  font-size: 12px;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 8px;
}

.action-buttons button {
  flex: 1;
  font-size: 14px;
  padding: 8px;
  border-radius: 4px;
}

.btn-favorite {
  background-color: #f0f0f0;
  color: #666;
}

.btn-favorite.favorited {
  background-color: #ff4757;
  color: #fff;
}

.btn-rating {
  background-color: #ffa726;
  color: #fff;
}

.btn-share {
  background-color: #42a5f5;
  color: #fff;
}

/* 标签页导航 */
.tab-nav {
  display: flex;
  background-color: #fff;
  margin-bottom: 10px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 14px;
  color: #666;
  border-bottom: 2px solid transparent;
}

.tab-item.active {
  color: #007aff;
  border-bottom-color: #007aff;
}

/* 标签页内容 */
.tab-content {
  flex: 1;
  background-color: #fff;
  padding: 16px;
}

/* 食材标签页 */
.servings-selector {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  font-size: 14px;
  color: #666;
}

.picker-display {
  margin-left: 8px;
  padding: 4px 8px;
  background-color: #f0f0f0;
  border-radius: 4px;
}

.ingredients-list {
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.ingredient-item.checked {
  opacity: 0.6;
}

.ingredient-item .ingredient-content {
  margin-left: 12px;
  flex: 1;
}

.ingredient-content .name {
  font-size: 14px;
  color: #333;
  margin-bottom: 4px;
}

.ingredient-content .amount {
  font-size: 12px;
  color: #666;
}

/* 做法标签页 */
.instructions-list {
  padding: 0;
}

.instruction-item {
  display: flex;
  margin-bottom: 16px;
  padding: 12px;
  background-color: #f8f9fa;
  border-radius: 8px;
}

.step-number {
  width: 24px;
  height: 24px;
  background-color: #007aff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: bold;
  margin-right: 12px;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 14px;
  color: #333;
  line-height: 1.5;
}

/* 营养标签页 */
.nutrition-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}

.nutrition-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background-color: #f8f9fa;
  border-radius: 8px;
}

.nutrition-item .label {
  font-size: 14px;
  color: #666;
}

.nutrition-item .value {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.nutrition-analysis {
  padding: 16px;
  background-color: #e3f2fd;
  border-radius: 8px;
}

.analysis-title {
  font-size: 16px;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 8px;
}

.recommendations {
  margin-bottom: 12px;
}

.recommendations text {
  display: block;
  font-size: 14px;
  color: #1976d2;
  margin-bottom: 4px;
}

.btn-analysis {
  width: 100%;
  background-color: #1976d2;
  color: #fff;
  font-size: 14px;
  padding: 8px;
  border-radius: 4px;
}

/* 推荐标签页 */
.recommendations-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.recommendation-item {
  display: flex;
  padding: 12px;
  background-color: #f8f9fa;
  border-radius: 8px;
}

.rec-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  margin-right: 12px;
}

.rec-info {
  flex: 1;
}

.rec-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.rec-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

/* 底部操作栏 */
.bottom-bar {
  padding: 16px;
  background-color: #fff;
  border-top: 1px solid #f0f0f0;
}

.btn-primary {
  width: 100%;
  background-color: #007aff;
  color: #fff;
  font-size: 16px;
  padding: 12px;
  border-radius: 8px;
}

/* 评分弹窗 */
.rating-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 8px;
  padding: 20px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.modal-header text {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.rating-stars {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.star {
  font-size: 32px;
  color: #ddd;
  margin: 0 4px;
  cursor: pointer;
}

.star.active {
  color: #ffa726;
}

.modal-actions {
  display: flex;
  gap: 12px;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 10px;
  border-radius: 4px;
  font-size: 14px;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666;
}

.btn-confirm {
  background-color: #007aff;
  color: #fff;
}

/* 加载和错误状态 */
.loading, .error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}

.error button {
  margin-top: 12px;
  padding: 8px 16px;
  background-color: #007aff;
  color: #fff;
  border-radius: 4px;
  font-size: 14px;
}