/* pages/nutrition-analyzer/nutrition-analyzer.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 头部操作栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 8px;
}

.btn-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

/* 标签页导航 */
.tab-nav {
  display: flex;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 14px;
  color: #666;
  border-bottom: 2px solid transparent;
}

.tab-item.active {
  color: #007aff;
  border-bottom-color: #007aff;
}

/* 标签页内容 */
.tab-content {
  flex: 1;
  padding: 16px;
}

/* 营养目标概览 */
.goals-overview {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.subtitle {
  font-size: 14px;
  color: #666;
}

.edit-btn {
  font-size: 14px;
  color: #007aff;
}

.goals-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.goal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background-color: #f8f9fa;
  border-radius: 8px;
}

.goal-item .value {
  font-size: 18px;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 2px;
}

.goal-item .unit {
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
}

.goal-item .label {
  font-size: 12px;
  color: #666;
}

/* 当前营养信息 */
.current-nutrition {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 16px;
}

.nutrition-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.nutrition-item {
  display: flex;
  align-items: center;
  gap: 12px;
}

.progress-bar {
  flex: 1;
  height: 8px;
  background-color: #e0e0e0;
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #007aff;
  border-radius: 4px;
  transition: width 0.3s ease;
}

.progress-fill.protein {
  background-color: #ff9800;
}

.progress-fill.carbs {
  background-color: #4caf50;
}

.progress-fill.fat {
  background-color: #f44336;
}

.nutrition-info {
  min-width: 80px;
  text-align: right;
}

.nutrition-info .value {
  font-size: 14px;
  font-weight: bold;
  color: #333;
}

.nutrition-info .unit {
  font-size: 12px;
  color: #666;
}

.nutrition-info .label {
  font-size: 10px;
  color: #999;
}

/* 营养建议 */
.recommendations {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.recommendation-list {
  margin-top: 12px;
}

.recommendation-item {
  margin-bottom: 8px;
  padding: 8px;
  background-color: #e3f2fd;
  border-radius: 4px;
}

.recommendation-text {
  font-size: 14px;
  color: #1976d2;
  line-height: 1.4;
}

/* 详情标签页 */
.breakdown-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.breakdown-item {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.recipe-header {
  display: flex;
  margin-bottom: 12px;
}

.recipe-image {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  margin-right: 12px;
}

.recipe-info {
  flex: 1;
}

.recipe-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-meta {
  font-size: 12px;
  color: #666;
}

.recipe-nutrition {
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.nutrition-row {
  font-size: 14px;
  color: #666;
  margin-bottom: 4px;
}

/* 推荐标签页 */
.meal-recommendations {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.recommendation-card {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.meal-type {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.meal-calories {
  font-size: 14px;
  color: #007aff;
  font-weight: bold;
}

.meal-recipes {
  font-size: 14px;
  color: #666;
}

.recipe-name {
  display: block;
  margin-bottom: 2px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300px;
  color: #999;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 14px;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 400px;
  background-color: #fff;
  border-radius: 8px;
  padding: 20px;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.modal-header text {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.goal-inputs {
  margin-bottom: 20px;
}

.input-group {
  margin-bottom: 16px;
}

.input-label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}

input {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
}

.modal-actions {
  display: flex;
  gap: 12px;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}