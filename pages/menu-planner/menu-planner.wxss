/* pages/menu-planner/menu-planner.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 头部操作栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 8px;
}

.btn-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  border: none;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 12px 16px;
  margin-bottom: 10px;
  border-bottom: 1px solid #f0f0f0;
}

.search-bar input {
  flex: 1;
  margin-left: 8px;
  font-size: 14px;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: flex-start;
  background-color: #fff;
  padding: 12px 16px;
  margin-bottom: 10px;
  border-bottom: 1px solid #f0f0f0;
}

.sort-label {
  font-size: 14px;
  color: #666;
  margin-right: 12px;
  margin-top: 6px;
}

.sort-options {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.sort-btn {
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 12px;
  background-color: #f0f0f0;
  color: #666;
  border: none;
}

.sort-btn.active {
  background-color: #007aff;
  color: #fff;
}

/* 菜单列表 */
.menus-list {
  flex: 1;
  background-color: #fff;
  padding: 0 16px 16px;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.menu-content {
  flex: 1;
  cursor: pointer;
}

.menu-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.menu-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.menu-actions {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.btn-small {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #007aff;
  color: #fff;
  border: none;
}

.btn-small.danger {
  background-color: #ff4757;
}

.menu-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.menu-recipes {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.recipe-name {
  background-color: #e6f7ff;
  color: #007aff;
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 12px;
}

.more-recipes {
  color: #999;
  font-size: 12px;
  align-self: center;
}

.menu-side-actions {
  margin-left: 12px;
}

.btn-icon-small {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300px;
  color: #999;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 14px;
  margin-bottom: 16px;
}

.btn-create-first {
  padding: 8px 16px;
  background-color: #007aff;
  color: #fff;
  border-radius: 4px;
  font-size: 14px;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}