/* pages/menu-detail/menu-detail.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 菜单头部 */
.menu-header {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 10px;
}

.menu-info {
  margin-bottom: 12px;
}

.menu-name {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.menu-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

.menu-actions {
  display: flex;
  gap: 8px;
}

.btn-action {
  flex: 1;
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #f0f0f0;
  color: #666;
}

.btn-action.danger {
  background-color: #ff4757;
  color: #fff;
}

/* 营养概览 */
.nutrition-overview {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 10px;
}

.overview-header {
  margin-bottom: 16px;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.subtitle {
  font-size: 12px;
  color: #666;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background-color: #f8f9fa;
  border-radius: 8px;
}

.nutrition-item .value {
  font-size: 18px;
  font-weight: bold;
  color: #007aff;
  margin-bottom: 2px;
}

.nutrition-item .unit {
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
}

.nutrition-item .label {
  font-size: 12px;
  color: #666;
}

.nutrition-analysis {
  padding: 12px;
  background-color: #e3f2fd;
  border-radius: 8px;
}

.analysis-title {
  font-size: 14px;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 8px;
}

.recommendations {
  font-size: 12px;
  color: #1976d2;
}

.recommendation {
  margin-bottom: 4px;
}

/* 菜谱列表 */
.recipes-section {
  flex: 1;
  background-color: #fff;
  margin-bottom: 80px; /* 为底部操作栏留空间 */
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.recipes-list {
  padding: 0 16px 16px;
}

.recipe-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.recipe-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  margin-right: 12px;
}

.recipe-content {
  flex: 1;
}

.recipe-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.recipe-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 8px;
}

.recipe-actions {
  display: flex;
  gap: 4px;
}

.btn-small {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #f0f0f0;
  color: #666;
}

.btn-small.danger {
  background-color: #ff4757;
  color: #fff;
}

.recipe-meta {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.tag {
  background-color: #e6f7ff;
  color: #007aff;
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 10px;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 16px;
  display: flex;
  gap: 8px;
  border-top: 1px solid #f0f0f0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}

/* 加载和空状态 */
.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}

.empty button {
  margin-top: 12px;
  padding: 8px 16px;
  background-color: #007aff;
  color: #fff;
  border-radius: 4px;
  font-size: 14px;
}