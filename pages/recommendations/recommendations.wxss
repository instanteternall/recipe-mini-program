/* pages/recommendations/recommendations.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 类别标签页 */
.category-tabs {
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
  white-space: nowrap;
}

.category-tab {
  display: inline-block;
  padding: 12px 16px;
  text-align: center;
  border-bottom: 2px solid transparent;
  transition: all 0.3s ease;
}

.category-tab.active {
  border-bottom-color: #007aff;
  background-color: #f8f9fa;
}

.tab-icon {
  font-size: 16px;
  margin-bottom: 4px;
  display: block;
}

.tab-name {
  font-size: 12px;
  color: #666;
}

.category-tab.active .tab-name {
  color: #007aff;
  font-weight: bold;
}

/* 推荐列表 */
.recommendations-list {
  flex: 1;
  padding: 16px;
}

.recommendation-card {
  background-color: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.recipe-image {
  width: 100%;
  height: 150px;
}

.card-content {
  padding: 16px;
}

.recipe-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.recipe-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 8px;
}

.recipe-actions {
  display: flex;
  gap: 8px;
}

.btn-favorite, .btn-detail {
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  border: none;
}

.btn-favorite {
  background-color: #ffebee;
  color: #e91e63;
}

.btn-detail {
  background-color: #007aff;
  color: #fff;
}

.recipe-meta {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 12px;
}

.tag {
  background-color: #e6f7ff;
  color: #007aff;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 12px;
}

.recommendation-reason {
  background-color: #fff3cd;
  padding: 8px 12px;
  border-radius: 6px;
  border-left: 3px solid #ffc107;
}

.reason-text {
  font-size: 12px;
  color: #856404;
  line-height: 1.4;
}

/* 操作栏 */
.action-bar {
  background-color: #fff;
  padding: 16px;
  display: flex;
  gap: 12px;
  border-top: 1px solid #f0f0f0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300px;
  color: #999;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 14px;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}