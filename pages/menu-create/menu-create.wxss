/* pages/menu-create/menu-create.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 菜单名称输入 */
.menu-name-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 10px;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.name-input {
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
}

/* 已选择菜谱 */
.selected-section {
  background-color: #fff;
  margin-bottom: 10px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.selected-list {
  padding: 0 16px 16px;
}

.selected-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.recipe-image {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  margin-right: 12px;
}

.recipe-info {
  flex: 1;
}

.recipe-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

.remove-btn {
  padding: 8px;
}

/* 搜索栏 */
.search-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 10px;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 20px;
  padding: 8px 12px;
}

.search-input {
  flex: 1;
  margin-left: 8px;
  font-size: 14px;
}

/* 可用菜谱 */
.available-section {
  flex: 1;
  background-color: #fff;
  margin-bottom: 80px; /* 为底部操作栏留空间 */
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 16px;
}

.recipe-card {
  background-color: #f8f9fa;
  border-radius: 8px;
  padding: 12px;
  position: relative;
}

.recipe-card .recipe-image {
  width: 100%;
  height: 80px;
  border-radius: 4px;
  margin-bottom: 8px;
}

.recipe-card .recipe-info {
  margin-bottom: 8px;
}

.recipe-card .recipe-title {
  font-size: 12px;
  margin-bottom: 4px;
}

.recipe-card .recipe-meta {
  font-size: 10px;
  color: #666;
}

.add-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空状态和加载状态 */
.empty-state, .loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
  font-size: 14px;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 16px;
  display: flex;
  gap: 12px;
  border-top: 1px solid #f0f0f0;
}

.btn-cancel, .btn-save {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  font-size: 16px;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666;
}

.btn-save {
  background-color: #007aff;
  color: #fff;
}