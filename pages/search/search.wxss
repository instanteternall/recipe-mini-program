/* pages/search/search.wxss */
.container {
  padding: 16px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-section {
  margin-bottom: 20px;
}

.search-bar {
  background-color: #fff;
  border-radius: 20px;
  padding: 8px 16px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.search-bar input {
  flex: 1;
  margin: 0 8px;
  font-size: 14px;
}

.search-btn {
  color: #007aff;
  font-size: 14px;
  padding: 4px 8px;
  border-radius: 12px;
  background-color: #f0f0f0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 14px;
  color: #666;
}

.history-tags, .hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  background-color: #f0f0f0;
  color: #666;
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 14px;
}

.hot-tag {
  background-color: #007aff;
  color: #fff;
}

.results-section {
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.results-list {
  margin-bottom: 16px;
}

.result-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.recipe-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  margin-right: 12px;
}

.recipe-info {
  flex: 1;
}

.title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: flex;
  margin-bottom: 8px;
  font-size: 12px;
  color: #666;
}

.meta text {
  margin-right: 12px;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.tag {
  background-color: #e6f7ff;
  color: #007aff;
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 12px;
}

.load-more {
  text-align: center;
  padding: 12px;
  color: #007aff;
  font-size: 14px;
}

.no-results {
  text-align: center;
  padding: 40px;
  color: #999;
}

.no-results text {
  display: block;
  margin-bottom: 8px;
}

.loading {
  text-align: center;
  padding: 40px;
  color: #999;
}