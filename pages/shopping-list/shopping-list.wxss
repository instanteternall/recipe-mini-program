/* pages/shopping-list/shopping-list.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 头部信息 */
.header-info {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 10px;
}

.menu-name {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.progress {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.progress-bar {
  height: 4px;
  background-color: #e0e0e0;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4caf50;
  border-radius: 2px;
  transition: width 0.3s ease;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 12px 16px;
  margin-bottom: 10px;
}

.left-actions, .right-actions {
  display: flex;
  gap: 8px;
}

.btn-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  border: none;
}

.btn-small {
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 12px;
  background-color: #f0f0f0;
  color: #666;
  border: none;
}

.btn-small.danger {
  background-color: #ff4757;
  color: #fff;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 12px 16px;
  margin-bottom: 10px;
}

.search-bar input {
  flex: 1;
  margin-left: 8px;
  font-size: 14px;
}

/* 购物清单 */
.shopping-list {
  flex: 1;
  background-color: #fff;
}

.list-content {
  padding: 0 16px 16px;
}

/* 分类组 */
.category-group {
  margin-bottom: 20px;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
  background-color: #f8f9fa;
  margin: 0 -16px 8px -16px;
  padding: 12px 16px;
}

.category-name {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.category-count {
  font-size: 14px;
  color: #666;
}

.category-items {
  padding-left: 8px;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
  transition: all 0.2s ease;
}

.list-item.checked {
  opacity: 0.6;
  text-decoration: line-through;
}

.list-item checkbox {
  margin-right: 12px;
}

.item-content {
  flex: 1;
}

.item-name {
  font-size: 16px;
  color: #333;
  margin-bottom: 4px;
  display: block;
}

.item-amount {
  font-size: 14px;
  color: #666;
}

.item-sources {
  margin-left: 8px;
}

.sources-text {
  font-size: 12px;
  color: #999;
}

.item-category {
  margin-left: 8px;
}

.category-tag {
  background-color: #e6f7ff;
  color: #007aff;
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 10px;
}

/* 底部操作栏 */
.bottom-bar {
  background-color: #fff;
  padding: 16px;
  display: flex;
  gap: 8px;
  border-top: 1px solid #f0f0f0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300px;
  color: #999;
  text-align: center;
}

.empty-text {
  font-size: 16px;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 14px;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
  color: #999;
}